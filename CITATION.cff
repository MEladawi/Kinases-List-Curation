    given-names: Mahmoud
    orcid: "https://orcid.org/0000-0003-1383-834X"
version: 1.0.0
date-released: "2026-06-06"
license: MIT
repository-code: "https://github.com/MEladawi/Kinases-List-Curation"
url: "https://github.com/MEladawi/Kinases-List-Curation"
keywords:
